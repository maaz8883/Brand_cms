							"cookie": [],
							"body": "{\n    \"success\": true,\n    \"data\": [\n        {\n            \"id\": 1,\n            \"title\": \"Sample Blog Title\",\n            \"slug\": \"sample-blog-title\",\n            \"content\": \"<p>Blog content here</p>\",\n            \"featured_image\": \"http://localhost:8000/storage/blogs/image.jpg\",\n            \"status\": \"published\",\n            \"user_id\": 1,\n            \"created_at\": \"2024-01-01T00:00:00.000000Z\",\n            \"updated_at\": \"2024-01-01T00:00:00.000000Z\",\n            \"user\": {\n                \"id\": 1,\n                \"name\": \"Admin\",\n                \"email\": \"admin@example.com\"\n            }\n        }\n    ]\n}"
